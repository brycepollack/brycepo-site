---
import Layout from '@/layouts/Layout.astro';
import profileImage from '@/assets/profile.jpg';
import { getEntry } from 'astro:content';

const entry = await getEntry('pages', 'home');
const { Content } = await entry.render();
---

<Layout title="Bryce Pollack">
  <div class="fade-up-container">
    <div class="profile-container">
      <div class="profile-image-container">
        <img
          src={profileImage.src}
          alt="Profile photo"
          class="profile-image"
          fetchpriority="high"
        />
      </div>
    </div>

    <article class="markdown-content">
      <Content />
    </article>
  </div>
</Layout>

<script>
  const img = document.querySelector<HTMLImageElement>('.profile-image');
  const container = document.querySelector('.fade-up-container');

  function ready() {
    container?.classList.add('ready');
  }

  if (img?.complete) {
    ready();
  } else {
    img?.addEventListener('load', ready);
    img?.addEventListener('error', ready);
  }
</script>
